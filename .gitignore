# ===== KEY MATERIAL — NEVER COMMIT =====
# These patterns must always remain in .gitignore. Adding a new file matching
# these patterns to the repo is a security incident.
*.wif
*.key
*.privkey
*.mnemonic
*.seed
*.secret
*-keys.json
keystore.json
taker-*.json
maker-*.json
# Gravity trade state / test files — historically contained private keys
gravity_*state*.json
gravity_sentinel_test.json
gravity_*.json
# Wallet files
wallet.dat
wallet*.dat
*.wallet

# ===== ENV + CREDS =====
.env
.env.*
.pypirc

# ===== Editor / IDE =====
*.code-workspace
.idea/
*.swp
*.swo
*~

# ===== Logs / temp =====
*.log
*.tmp

# ===== Strategic / unreleased design work =====
# Strategic exploration, in-progress design docs, and pre-publication
# notes live in docs/design/ and are not tracked by default. Public
# research artifacts (like wallet derivation findings) belong in
# docs/research/ and are tracked normally.
#
# To commit a single file from docs/design/ deliberately (e.g. when
# moving it from internal to public), use:
#   git add -f docs/design/<filename>
# This makes the publication an explicit, deliberate act rather than
# something that could happen via `git add .`
docs/design/

# ===== Local-only dev environment =====
# Machine-local tooling state and generated output. None of this is
# portable or meaningful to another contributor; keeping it untracked
# leaves `git status` clean for everyone.
#
# .claude/      — Claude Code per-machine config
# .worktrees/   — git worktree checkouts (local-only by definition)
# logs/         — fuzz / diagnostic run output (scripts/fuzz_*.sh)
# poetry.lock   — library project; deps resolve from pyproject.toml
.claude/
.worktrees/
logs/
poetry.lock

