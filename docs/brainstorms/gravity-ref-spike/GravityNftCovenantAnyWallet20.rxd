            }
            // else: sentinel 0x02 — padding level, current passes through unchanged
            // Extract merkleRoot from each header
            bytes root1 = h1.split(36)[1].split(32)[0];
            bytes root2 = h2.split(36)[1].split(32)[0];
            bytes root3 = h3.split(36)[1].split(32)[0];
            bytes root4 = h4.split(36)[1].split(32)[0];
