            bytes root11 = h11.split(36)[1].split(32)[0];
            bytes root12 = h12.split(36)[1].split(32)[0];
            require(current == root1 || current == root2 || current == root3 || current == root4 || current == root5 || current == root6 || current == root7 || current == root8 || current == root9 || current == root10 || current == root11 || current == root12);

            // --- Any-wallet output scan: find the maker payment >= btcSatoshis ---
            // Matches all 4 BTC output types (P2WPKH/P2PKH/P2SH/P2TR) at ANY
            // output index (change anywhere). Each output: value(8) + scriptLen
            // varint(1) + script(scriptLen). btcReceiveHash = maker's committed
            // hash (20B for the first three, 32B for P2TR).
            bool found = false;
            int v1 = int(rawTx.split(pos)[1].split(8)[0]);
            int sl1 = int(rawTx.split(pos + 8)[1].split(1)[0]);
            if (sl1 == 22) { if (rawTx.split(pos + 9)[1].split(2)[0] == 0x0014) { if (rawTx.split(pos + 11)[1].split(20)[0] == btcReceiveHash) { if (v1 >= btcSatoshis) { found = true; } } } }
            if (sl1 == 25) { if (rawTx.split(pos + 9)[1].split(3)[0] == 0x76a914) { if (rawTx.split(pos + 12)[1].split(20)[0] == btcReceiveHash) { if (rawTx.split(pos + 32)[1].split(2)[0] == 0x88ac) { if (v1 >= btcSatoshis) { found = true; } } } } }
            if (sl1 == 23) { if (rawTx.split(pos + 9)[1].split(2)[0] == 0xa914) { if (rawTx.split(pos + 11)[1].split(20)[0] == btcReceiveHash) { if (rawTx.split(pos + 31)[1].split(1)[0] == 0x87) { if (v1 >= btcSatoshis) { found = true; } } } } }
            if (sl1 == 34) { if (rawTx.split(pos + 9)[1].split(2)[0] == 0x5120) { if (rawTx.split(pos + 11)[1].split(32)[0] == btcReceiveHash) { if (v1 >= btcSatoshis) { found = true; } } } }
            pos = pos + 9 + sl1;
            if (nOut >= 2) {
            int v2 = int(rawTx.split(pos)[1].split(8)[0]);
            int sl2 = int(rawTx.split(pos + 8)[1].split(1)[0]);
            if (sl2 == 22) { if (rawTx.split(pos + 9)[1].split(2)[0] == 0x0014) { if (rawTx.split(pos + 11)[1].split(20)[0] == btcReceiveHash) { if (v2 >= btcSatoshis) { found = true; } } } }
            if (sl2 == 25) { if (rawTx.split(pos + 9)[1].split(3)[0] == 0x76a914) { if (rawTx.split(pos + 12)[1].split(20)[0] == btcReceiveHash) { if (rawTx.split(pos + 32)[1].split(2)[0] == 0x88ac) { if (v2 >= btcSatoshis) { found = true; } } } } }
